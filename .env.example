GEMINI_TRANSPORT=app
GEMINI_APP_MODEL=auto-flash
GEMINI_APP_TEACHER_MODEL_KEY=gemini_webapi:auto-flash
GEMINI_WEBAPI_SECURE_1PSID=
GEMINI_WEBAPI_SECURE_1PSIDTS=
GEMINI_API_KEY=replace-with-your-key
GEMINI_TEACHER_MODEL=gemma-4-31b-it
GEMINI_TIMEOUT_SECONDS=300
GEMINI_MAX_OUTPUT_TOKENS=16384
GEMINI_USE_RESPONSE_SCHEMA=0
GEMINI_STOP_ON_QUOTA_COUNT=3
GEMINI_MIN_QUOTA_COOLDOWN_SECONDS=3600
GEMINI_SHORT_QUOTA_LIMIT_THRESHOLD=100
GEMMA4_TARGET_MODEL=google/gemma-4-E2B-it
GEMMA4_TEST_MODEL=google/gemma-4-31B-it
GEMMA4_VISUAL_TOKENS=1120
CHAT_TEMPLATE_PROCESSOR_LOAD_ATTEMPTS=3
CHAT_TEMPLATE_PROCESSOR_LOAD_SLEEP_SECONDS=5
PIPELINE_OUTPUT_DIR=artifacts/page_only_v1
